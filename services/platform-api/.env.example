APP_ENV=development
APP_NAME=ClusterWatch
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8000
DATABASE_URL=postgresql+asyncpg://clusterwatch:clusterwatch@postgres:5432/clusterwatch
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AGENT_TOKEN_SECRET=change-me-agent-token-secret
AGENT_TOKEN_EXPIRE_HOURS=720
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNoobqFeqCnf2VD3rENH04S2xNoS+REDACTED_FOR_DOCS_REPLACE_WITH_AZURITE_KEY;BlobEndpoint=http://azurite:10000/devstoreaccount1;
AZURE_STORAGE_CONTAINER=clusterwatch-data
LOG_BATCH_MAX_SIZE_MB=10
LOG_RETENTION_DAYS=30
CORS_ALLOWED_ORIGINS=http://localhost:3000
AI_PROVIDER=disabled
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
